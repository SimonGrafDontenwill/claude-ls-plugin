{
  "name": "claude-ls-plugin",
  "version": "0.2.0",
  "description": "Claude Code plugin integrating the Codeblock (.dwp) and YAML Language Servers",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-ls-plugin": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "optionalDependencies": {
    "@dontenwill-standard/yaml-ls": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
